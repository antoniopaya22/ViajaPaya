# Copiar a .env.local (nunca comitear .env.local) y rellenar con los valores reales del proyecto Supabase.
# Variables EXPO_PUBLIC_* son visibles en el cliente (bundle de la app) — nunca poner ahí secretos de servidor.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Solo para uso local (CLI de Supabase, migraciones, conexión directa a la BBDD) — NUNCA en el cliente/app.
SUPABASE_PROJECT_ID=
SUPABASE_PROJECT_REGION=
SUPABASE_DB_PASSWORD=
